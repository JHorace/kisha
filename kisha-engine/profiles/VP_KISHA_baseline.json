{
    "$schema": "https://schema.khronos.org/vulkan/profiles-0.8.2-328.json#",
    "capabilities": {
        "kisha_baseline": {
            "extensions": {
                "VK_EXT_shader_object": 1,
                "VK_KHR_unified_image_layouts": 1,
                "VK_EXT_descriptor_buffer": 1,
                "VK_KHR_swapchain_maintenance1": 1
            },
            "features": {
                "VkPhysicalDeviceVulkan11Features": {
                    "shaderDrawParameters": true
                },
                "VkPhysicalDeviceVulkan12Features": {
                    "timelineSemaphore": true,
                    "bufferDeviceAddress": true
                },
                "VkPhysicalDeviceVulkan13Features": {
                    "dynamicRendering": true,
                    "synchronization2": true
                },
                "VkPhysicalDeviceShaderObjectFeaturesEXT": {
                    "shaderObject": true
                },
                "VkPhysicalDeviceUnifiedImageLayoutsFeaturesKHR": {
                    "unifiedImageLayouts": true
                },
                "VkPhysicalDeviceDescriptorBufferFeaturesEXT": {
                    "descriptorBuffer": true
                },
                "VkPhysicalDeviceSwapchainMaintenance1FeaturesKHR": {
                    "swapchainMaintenance1": true
                }
            }
        }
    },
    "profiles": {
        "VP_KISHA_baseline": {
            "version": 3,
            "api-version": "1.3.350",
            "label": "Kisha Engine baseline profile",
            "description": "Required extensions, features and API version for the kisha engine core.",
            "capabilities": [
                "kisha_baseline"
            ]
        }
    },
    "contributors": {},
    "history": [
        {
            "revision": 3,
            "date": "2026-06-13",
            "author": "kisha-engine",
            "comment": "Add VK_KHR_swapchain_maintenance1 (swapchainMaintenance1) requirement."
        },
        {
            "revision": 2,
            "date": "2026-06-13",
            "author": "kisha-engine",
            "comment": "Add VK_EXT_descriptor_buffer (descriptorBuffer + bufferDeviceAddress) requirement."
        },
        {
            "revision": 1,
            "date": "2026-06-13",
            "author": "kisha-engine",
            "comment": "Initial kisha engine baseline profile."
        }
    ]
}
